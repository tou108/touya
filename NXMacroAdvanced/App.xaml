<Application x:Class="NXMacroAdvanced.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- MaterialDesign テーマ (ダークテーマ) -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Blue"
                                             SecondaryColor="Red" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- アプリカラー -->
            <SolidColorBrush x:Key="NxPrimary"   Color="#1565C0"/>
            <SolidColorBrush x:Key="NxAccent"    Color="#E60012"/>
            <SolidColorBrush x:Key="NxSuccess"   Color="#43A047"/>
            <SolidColorBrush x:Key="NxWarning"   Color="#FB8C00"/>
            <SolidColorBrush x:Key="NxBg"        Color="#121212"/>
            <SolidColorBrush x:Key="NxSurface"   Color="#1E1E1E"/>
            <SolidColorBrush x:Key="NxSurface2"  Color="#2A2A2A"/>

            <!-- コントローラーボタン色 -->
            <SolidColorBrush x:Key="BtnA" Color="#FF4444"/>  <!-- 赤 -->
            <SolidColorBrush x:Key="BtnB" Color="#FFCC00"/>  <!-- 黄 -->
            <SolidColorBrush x:Key="BtnX" Color="#44AAFF"/>  <!-- 青 -->
            <SolidColorBrush x:Key="BtnY" Color="#44CC44"/>  <!-- 緑 -->

            <!-- 共通スタイル -->
            <Style x:Key="GamepadButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Width"          Value="52"/>
                <Setter Property="Height"         Value="52"/>
                <Setter Property="FontSize"       Value="14"/>
                <Setter Property="FontWeight"     Value="Bold"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="26"/>
                <Setter Property="Padding"        Value="0"/>
                <Setter Property="Margin"         Value="3"/>
            </Style>

            <Style x:Key="TriggerButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Width"   Value="72"/>
                <Setter Property="Height"  Value="36"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
                <Setter Property="Margin"  Value="3"/>
            </Style>

            <Style x:Key="DPadButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Width"   Value="36"/>
                <Setter Property="Height"  Value="36"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin"  Value="1"/>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize"     Value="13"/>
                <Setter Property="FontWeight"   Value="Medium"/>
                <Setter Property="Opacity"      Value="0.6"/>
                <Setter Property="Margin"       Value="0,12,0,4"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
