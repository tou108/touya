<Window x:Class="NXMacroAdvanced.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:NXMacroAdvanced.Views"
        xmlns:conv="clr-namespace:NXMacroAdvanced.Converters"
        Title="NX Macro Advanced — Nintendo Switch 全自動マクロツール"
        Height="780" Width="1180" MinHeight="600" MinWidth="900"
        Background="{StaticResource NxBg}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{md:MaterialDesignFont}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter   x:Key="BoolToVis"/>
        <conv:InverseBoolConverter        x:Key="InvBool"/>
        <conv:ConnectionStatusToColorConverter x:Key="StatusToColor"/>

        <!-- サイドナビボタンスタイル -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Width="72" Height="72" CornerRadius="12" Margin="4,2"
                                Background="Transparent" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <md:PackIcon x:Name="Icon" Width="26" Height="26"
                                             Kind="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                             HorizontalAlignment="Center" Foreground="White" Opacity="0.55"/>
                                <TextBlock x:Name="Lbl" Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="9" HorizontalAlignment="Center" Foreground="White"
                                           Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"   Property="Background" Value="#1E4A8C"/>
                                <Setter TargetName="Icon" Property="Opacity"    Value="1"/>
                                <Setter TargetName="Lbl"  Property="Opacity"    Value="1"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#90CAF9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3A6C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>   <!-- サイドナビ -->
            <ColumnDefinition Width="*"/>    <!-- メインコンテンツ -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 左サイドナビゲーション -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="#0D1B3E">
            <DockPanel>
                <!-- ロゴ -->
                <StackPanel DockPanel.Dock="Top" Margin="0,14,0,10">
                    <md:PackIcon Kind="GamepadVariant" Width="34" Height="34"
                                 Foreground="#E60012" HorizontalAlignment="Center"/>
                    <TextBlock Text="NX" FontSize="13" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    <TextBlock Text="Macro" FontSize="9" Foreground="#90CAF9"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#1A3A6C" Margin="10,0"/>

                <!-- ナビボタン -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <RadioButton Style="{StaticResource NavButton}" Tag="Connection"
                                 Content="接続" GroupName="Nav"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource InvBool}, Mode=OneWay}"
                                 Command="{Binding SelectTabCommand}" CommandParameter="0"/>
                    <RadioButton Style="{StaticResource NavButton}" Tag="GamepadVariant"
                                 Content="コントローラー" GroupName="Nav"
                                 Command="{Binding SelectTabCommand}" CommandParameter="1"/>
                    <RadioButton Style="{StaticResource NavButton}" Tag="CodeBraces"
                                 Content="エディタ" GroupName="Nav"
                                 Command="{Binding SelectTabCommand}" CommandParameter="2"/>
                    <RadioButton Style="{StaticResource NavButton}" Tag="VectorPolyline"
                                 Content="ビジュアル" GroupName="Nav"
                                 Command="{Binding SelectTabCommand}" CommandParameter="3"/>
                    <RadioButton Style="{StaticResource NavButton}" Tag="RecordCircle"
                                 Content="録音" GroupName="Nav"
                                 Command="{Binding SelectTabCommand}" CommandParameter="4"/>
                    <RadioButton Style="{StaticResource NavButton}" Tag="CalendarClock"
                                 Content="スケジュール" GroupName="Nav"
                                 Command="{Binding SelectTabCommand}" CommandParameter="5"/>
                    <RadioButton Style="{StaticResource NavButton}" Tag="ImageSearch"
                                 Content="画像認識" GroupName="Nav"
                                 Command="{Binding SelectTabCommand}" CommandParameter="6"/>
                </StackPanel>

                <!-- マクロ実行ステータス (下部) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,16">
                    <Separator Background="#1A3A6C" Margin="10,0,10,8"/>
                    <!-- 実行中インジケーター -->
                    <Border CornerRadius="6" Background="#0A2040" Margin="6,0" Padding="4">
                        <StackPanel>
                            <md:PackIcon Kind="PlayCircle" Width="22" Height="22"
                                         Foreground="{StaticResource NxSuccess}"
                                         HorizontalAlignment="Center"
                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                            <md:PackIcon Kind="StopCircle" Width="22" Height="22"
                                         Foreground="#555" HorizontalAlignment="Center"
                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}"/>
                            <ProgressBar Value="{Binding MacroProgress}" Height="4"
                                         Margin="4,4,4,0" Foreground="{StaticResource NxSuccess}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 接続状態ドット -->
                <Ellipse DockPanel.Dock="Bottom" Width="10" Height="10" Margin="0,6"
                         HorizontalAlignment="Center"
                         Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- メインコンテンツエリア (TabControl) -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TabControl Grid.Column="1" Grid.Row="0"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    TabStripPlacement="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{x:Null}">

            <!-- スタイルでタブヘッダーを非表示にする -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- タブ 0: 接続設定 -->
            <TabItem>
                <views:ConnectionView DataContext="{Binding ConnectionVM}"/>
            </TabItem>

            <!-- タブ 1: バーチャルコントローラー -->
            <TabItem>
                <views:ControllerView DataContext="{Binding ControllerVM}"/>
            </TabItem>

            <!-- タブ 2: マクロテキストエディター -->
            <TabItem>
                <views:MacroEditorView DataContext="{Binding MacroEditorVM}"/>
            </TabItem>

            <!-- タブ 3: ビジュアルスクリプトエディター -->
            <TabItem>
                <views:VisualScriptEditorView/>
            </TabItem>

            <!-- タブ 4: マクロ録音 -->
            <TabItem>
                <views:RecorderView DataContext="{Binding RecorderVM}"/>
            </TabItem>

            <!-- タブ 5: スケジューラー -->
            <TabItem>
                <views:SchedulerView DataContext="{Binding SchedulerVM}"/>
            </TabItem>

            <!-- タブ 6: 画像認識・OCR -->
            <TabItem>
                <views:ImageRecognitionView DataContext="{Binding ImageRecognitionVM}"/>
            </TabItem>
        </TabControl>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ステータスバー -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="1" Background="#0D1B3E" Height="34">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 接続状態 -->
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                <!-- マクロ停止ボタン (実行中のみ表示) -->
                <Button Grid.Column="1" Content="⏹ 停止"
                        Command="{Binding StopMacroCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#FF5252" FontSize="11" Height="26" Margin="8,0"/>

                <!-- 一時停止 -->
                <Button Grid.Column="2" Content="⏸"
                        Command="{Binding PauseMacroCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        FontSize="13" Height="26" Margin="0,0,8,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
