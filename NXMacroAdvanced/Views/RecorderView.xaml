<UserControl x:Class="NXMacroAdvanced.Views.RecorderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:NXMacroAdvanced.Converters"
             Background="{StaticResource NxBg}">
  <UserControl.Resources>
    <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <conv:InverseBoolConverter      x:Key="InvBool"/>
  </UserControl.Resources>
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="⏺ マクロ録音" FontSize="22" FontWeight="Light" Foreground="White" Margin="0,0,0,20"/>

    <!-- 録音コントロール -->
    <Border Grid.Row="1" Background="{StaticResource NxSurface}" CornerRadius="10" Padding="20" Margin="0,0,0,16">
      <StackPanel>
        <TextBox Text="{Binding RecordingName}" md:HintAssist.Hint="録音名"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,16" Width="300" HorizontalAlignment="Left"/>
        <WrapPanel>
          <Button Command="{Binding StartRecordingCommand}"
                  IsEnabled="{Binding IsRecording, Converter={StaticResource InvBool}}"
                  Style="{StaticResource MaterialDesignRaisedButton}" Background="#B71C1C"
                  Height="44" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="10" Height="10" Fill="Red" Margin="0,0,8,0" VerticalAlignment="Center"/>
              <TextBlock Text="録音開始" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding StopRecordingCommand}"
                  IsEnabled="{Binding IsRecording}"
                  Style="{StaticResource MaterialDesignRaisedButton}" Background="#424242"
                  Height="44" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal">
              <md:PackIcon Kind="Stop" Margin="0,0,8,0" VerticalAlignment="Center"/>
              <TextBlock Text="録音停止" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding ClearRecordingCommand}"
                  Style="{StaticResource MaterialDesignOutlinedButton}" Height="44" Margin="0,0,12,0">
            <TextBlock Text="🗑 クリア"/>
          </Button>
          <Button Command="{Binding ExportScriptCommand}"
                  IsEnabled="{Binding IsRecording, Converter={StaticResource InvBool}}"
                  Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource NxPrimary}"
                  Height="44">
            <StackPanel Orientation="Horizontal">
              <md:PackIcon Kind="ContentSave" Margin="0,0,8,0" VerticalAlignment="Center"/>
              <TextBlock Text="ファイルに保存" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </WrapPanel>

        <!-- 録音状態 -->
        <Border Margin="0,16,0,0" Padding="12,8" CornerRadius="6"
                Background="{Binding IsRecording, Converter={conv:BoolToBrushConverter}, ConverterParameter=#B71C1C20|#00000000}">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#555"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                      <Setter Property="Fill" Value="Red"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock VerticalAlignment="Center" FontSize="13">
              <Run Text="{Binding IsRecording, Converter={conv:BoolToStringConverter}, ConverterParameter=録音中...|待機中}"/>
              <Run Text=" — "/>
              <Run Text="{Binding EventCount}"/>
              <Run Text=" イベント記録済み"/>
            </TextBlock>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <!-- 生成されたスクリプト -->
    <Border Grid.Row="2" Background="{StaticResource NxSurface}" CornerRadius="10" Padding="0" ClipToBounds="True">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{StaticResource NxSurface2}">
          <TextBlock Text="📝 生成されたスクリプト" FontSize="13" FontWeight="Medium" Foreground="#90CAF9"/>
        </Border>
        <TextBox Text="{Binding ExportedScript}" AcceptsReturn="True"
                 FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                 Background="Transparent" BorderThickness="0" Padding="16"
                 VerticalScrollBarVisibility="Auto"/>
      </DockPanel>
    </Border>

    <!-- 操作ガイド -->
    <Border Grid.Row="3" Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,12,0,0">
      <TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap">
        💡 録音の使い方: バーチャルコントローラータブでボタンをクリックしながら録音すると、その操作がマクロとして記録されます。&#10;
        録音停止後、スクリプトが自動生成されます。「ファイルに保存」でマクロエディターから読み込めます。
      </TextBlock>
    </Border>
  </Grid>
</UserControl>
