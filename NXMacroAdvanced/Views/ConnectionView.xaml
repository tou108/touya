<UserControl x:Class="NXMacroAdvanced.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:NXMacroAdvanced.Converters"
             Background="{StaticResource NxBg}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumEqualityConverter     x:Key="EnumEq"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,20" MaxWidth="700">

            <!-- タイトル -->
            <TextBlock Text="接続設定" FontSize="22" FontWeight="Light" Foreground="White" Margin="0,0,0,20"/>

            <!-- ─── 接続タイプ選択 ─── -->
            <TextBlock Text="接続方式" Style="{StaticResource SectionHeader}"/>
            <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <RadioButton Content="USB HID (Arduino / Teensy)  — 有線接続・最安定"
                                 IsChecked="{Binding SelectedType, Converter={StaticResource EnumEq}, ConverterParameter=UsbHid}"
                                 Foreground="White" Margin="0,4"/>
                    <RadioButton Content="USB Gadget (Raspberry Pi Zero)  — 有線・高機能"
                                 IsChecked="{Binding SelectedType, Converter={StaticResource EnumEq}, ConverterParameter=UsbGadget}"
                                 Foreground="White" Margin="0,4"/>
                    <RadioButton Content="Bluetooth 無線  — ワイヤレス接続"
                                 IsChecked="{Binding SelectedType, Converter={StaticResource EnumEq}, ConverterParameter=Bluetooth}"
                                 Foreground="White" Margin="0,4"/>
                </StackPanel>
            </Border>

            <!-- ─── USB HID 設定 ─── -->
            <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                    Visibility="{Binding SelectedType, Converter={StaticResource EnumEq}, ConverterParameter=UsbHid}">
                <StackPanel>
                    <TextBlock Text="USB HID 設定 (Arduino / Teensy)" FontWeight="Medium"
                               Foreground="#90CAF9" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding ComPort}"
                                  md:HintAssist.Hint="COM ポート"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,8,0"/>

                        <Button Grid.Column="1" Content="🔄 更新"
                                Command="{Binding RefreshPortsCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="2"
                                  md:HintAssist.Hint="ボーレート"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  SelectedItem="{Binding BaudRate}">
                            <ComboBox.Items>
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">9600</sys:Int32>
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">57600</sys:Int32>
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">115200</sys:Int32>
                            </ComboBox.Items>
                        </ComboBox>
                    </Grid>

                    <TextBlock Margin="0,12,0,0" FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                               Text="💡 Arduino Leonardo / Teensy 3.x/4.x / Pro Micro に SwitchController.ino を書き込んでください。"/>
                </StackPanel>
            </Border>

            <!-- ─── USB Gadget 設定 ─── -->
            <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                    Visibility="{Binding SelectedType, Converter={StaticResource EnumEq}, ConverterParameter=UsbGadget}">
                <StackPanel>
                    <TextBlock Text="USB Gadget 設定 (Raspberry Pi Zero W/2W)" FontWeight="Medium"
                               Foreground="#90CAF9" Margin="0,0,0,12"/>

                    <CheckBox Content="TCP/IP 接続を使用 (Wi-Fi / USB RNDIS)"
                              IsChecked="{Binding GadgetUseTcp}" Foreground="White" Margin="0,0,0,12"/>

                    <!-- Serial 設定 -->
                    <StackPanel Visibility="{Binding GadgetUseTcp, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}">
                        <ComboBox ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding GadgetComPort}"
                                  md:HintAssist.Hint="COM ポート (USB シリアル)"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>

                    <!-- TCP 設定 -->
                    <Grid Visibility="{Binding GadgetUseTcp, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding GadgetTcpIp}"
                                 md:HintAssist.Hint="IP アドレス (例: 192.168.7.1)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding GadgetTcpPort}"
                                 md:HintAssist.Hint="ポート"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </Grid>

                    <TextBlock Margin="0,10,0,0" FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                               Text="💡 RPi Zero を USB ケーブルで接続し、gadget_setup.sh を実行してください。&#10;   デフォルト IP: USB接続時 192.168.7.1、Wi-Fi 接続時はルーターで確認"/>
                </StackPanel>
            </Border>

            <!-- ─── Bluetooth 設定 ─── -->
            <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                    Visibility="{Binding SelectedType, Converter={StaticResource EnumEq}, ConverterParameter=Bluetooth}">
                <StackPanel>
                    <TextBlock Text="Bluetooth 設定" FontWeight="Medium"
                               Foreground="#90CAF9" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding BtAddress}"
                                 md:HintAssist.Hint="Bluetooth アドレス (例: AA:BB:CC:DD:EE:FF)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="🔍 スキャン"
                                Command="{Binding ScanBluetoothCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding BtDevices}"
                             SelectedValue="{Binding BtAddress}"
                             MaxHeight="120" Margin="0,0,0,8"
                             Background="{StaticResource NxSurface2}"/>

                    <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                               Text="💡 Switch の「コントローラーとセンサー」→「コントローラーの持ち方/順番を変える」でペアリングモードにしてからスキャンしてください。"/>
                </StackPanel>
            </Border>

            <!-- ─── 接続ボタン ─── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{Binding IsConnected, Converter={StaticResource BoolToVis},
                                  ConverterParameter=connected}"
                        Command="{Binding ConnectCommand}"
                        IsEnabled="{Binding IsConnecting, Converter={conv:InverseBoolConverter}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource NxPrimary}"
                        Height="44" FontSize="14"
                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Connection" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="接続する" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="0"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#B71C1C" Height="44" FontSize="14"
                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Disconnect" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="切断する" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 状態表示 -->
                <Border Grid.Column="1" CornerRadius="8" Padding="14,10"
                        Background="{StaticResource NxSurface}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF5252"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#69F0AE"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                            <Setter Property="Fill" Value="#FFD740"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── セットアップガイド ─── -->
            <Expander Header="📖 セットアップガイド" Foreground="White" Margin="0,8,0,0">
                <Border Background="{StaticResource NxSurface2}" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="【USB HID 接続手順】" FontWeight="Bold" Foreground="#90CAF9" Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" Foreground="#BDBDBD" TextWrapping="Wrap">
                            1. Arduino フォルダの SwitchController.ino を Arduino IDE で開く&#10;
                            2. ボードを「Arduino Leonardo」または「Teensy」に選択&#10;
                            3. Switch の USB ポートに Arduino を接続&#10;
                            4. PC と Arduino も USB で接続してスケッチを書き込み&#10;
                            5. COM ポートを選択して「接続する」をクリック
                        </TextBlock>
                        <TextBlock Text="【Bluetooth 接続手順】" FontWeight="Bold" Foreground="#90CAF9" Margin="0,12,0,6"/>
                        <TextBlock FontSize="12" Foreground="#BDBDBD" TextWrapping="Wrap">
                            1. Switch のホーム画面 →「コントローラーとセンサー」&#10;
                            2.「コントローラーの持ち方/順番を変える」→「コントローラーの登録」&#10;
                            3. 「スキャン」ボタンを押してデバイスを検索&#10;
                            4. 一覧に表示された Switch を選択して「接続する」
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
