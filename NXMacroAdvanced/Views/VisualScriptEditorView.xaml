<UserControl x:Class="NXMacroAdvanced.Views.VisualScriptEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource NxBg}"
             x:Name="Root">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>  <!-- ノードパレット -->
            <ColumnDefinition Width="*"/>    <!-- キャンバス -->
            <ColumnDefinition Width="200"/>  <!-- プロパティパネル -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════ ノードパレット（左） ═══════════ -->
        <Border Grid.Column="0" Background="{StaticResource NxSurface}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,10" Background="{StaticResource NxSurface2}">
                    <TextBlock Text="🧩 ノードパレット" FontSize="13" FontWeight="Medium" Foreground="#90CAF9"/>
                </Border>
                <ScrollViewer>
                    <StackPanel Margin="8">
                        <TextBlock Text="基本入力" Style="{StaticResource SectionHeader}"/>
                        <Button Content="▶ ボタン押下" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Press" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="⏸ 待機" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Wait" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="🕹 スティック" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Stick" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="✚ 十字キー" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="DPad" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>

                        <TextBlock Text="制御フロー" Style="{StaticResource SectionHeader}"/>
                        <Button Content="🔁 ループ" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Loop" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="❓ 条件分岐" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Condition" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="🏷 ラベル/GOTO" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Label" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>

                        <TextBlock Text="画像認識" Style="{StaticResource SectionHeader}"/>
                        <Button Content="👁 画像マッチ" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="ImageMatch" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="📝 OCR テキスト" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Ocr" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="⏳ 画像待機" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="WaitImage" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>
                        <Button Content="📷 スクリーンショット" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="Screenshot" HorizontalAlignment="Stretch"
                                Margin="0,2" FontSize="11"
                                Click="PaletteItem_Click"/>

                        <Separator Margin="0,12,0,8"/>
                        <Button Content="🗑 選択削除" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#FF5252" BorderBrush="#FF5252"
                                HorizontalAlignment="Stretch" Margin="0,2" FontSize="11"
                                Click="DeleteSelected_Click"/>
                        <Button Content="🔗 スクリプト生成" Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource NxPrimary}"
                                HorizontalAlignment="Stretch" Margin="0,4" FontSize="11"
                                Click="ExportScript_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ ノードキャンバス（中央） ═══════════ -->
        <Border Grid.Column="1" Background="#0A0F1E" ClipToBounds="True">
            <DockPanel>
                <!-- キャンバスツールバー -->
                <Border DockPanel.Dock="Top" Padding="8,4" Background="{StaticResource NxSurface}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="⟳ リセット表示" Style="{StaticResource MaterialDesignFlatButton}"
                                FontSize="11" Click="ResetView_Click"/>
                        <Button Content="➕ ズームイン" Style="{StaticResource MaterialDesignFlatButton}"
                                FontSize="11" Click="ZoomIn_Click"/>
                        <Button Content="➖ ズームアウト" Style="{StaticResource MaterialDesignFlatButton}"
                                FontSize="11" Click="ZoomOut_Click"/>
                        <Separator Margin="8,0"/>
                        <TextBlock Text="ノードをドラッグ&amp;ドロップで移動 | ポートをドラッグで接続"
                                   FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- スクロール可能なキャンバス -->
                <ScrollViewer x:Name="CanvasScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Canvas x:Name="NodeCanvas" Width="3000" Height="2000"
                            Background="Transparent"
                            MouseMove="Canvas_MouseMove"
                            MouseUp="Canvas_MouseUp"
                            MouseDown="Canvas_MouseDown">

                        <!-- グリッドドット背景 -->
                        <Canvas.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,32,32"
                                          ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#0D1B3E">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,32,32"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#1A2A4A">
                                            <GeometryDrawing.Geometry>
                                                <EllipseGeometry Center="0,0" RadiusX="1" RadiusY="1"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Canvas.Background>

                        <!-- 接続ライン (コードビハインドで動的生成) -->
                        <Canvas x:Name="ConnectionCanvas"/>

                        <!-- ノードコンテナ (コードビハインドで動的追加) -->
                        <Canvas x:Name="NodesCanvas"/>

                        <!-- スタートノード (固定) -->
                        <Border x:Name="StartNode"
                                Canvas.Left="100" Canvas.Top="100"
                                Width="130" Height="50"
                                CornerRadius="8" Background="#1B5E20"
                                BorderBrush="#69F0AE" BorderThickness="2"
                                Cursor="SizeAll"
                                MouseLeftButtonDown="Node_MouseDown">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="▶ START" FontSize="13" FontWeight="Bold"
                                           Foreground="#69F0AE" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </Canvas>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ プロパティパネル（右） ═══════════ -->
        <Border Grid.Column="2" Background="{StaticResource NxSurface}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,10" Background="{StaticResource NxSurface2}">
                    <TextBlock Text="⚙ プロパティ" FontSize="13" FontWeight="Medium" Foreground="#90CAF9"/>
                </Border>

                <ScrollViewer>
                    <StackPanel x:Name="PropertyPanel" Margin="12">
                        <!-- ノード選択時にコードビハインドで動的に生成 -->
                        <TextBlock Text="ノードを選択してください" Opacity="0.5" FontSize="12"
                                   TextWrapping="Wrap" x:Name="NoSelectionText"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
