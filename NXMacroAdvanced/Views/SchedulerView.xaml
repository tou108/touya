<UserControl x:Class="NXMacroAdvanced.Views.SchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:NXMacroAdvanced.Models"
             Background="{StaticResource NxBg}">
  <Grid Margin="24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="320"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="⏰ スケジューラー"
               FontSize="22" FontWeight="Light" Foreground="White" Margin="0,0,0,20"/>

    <!-- スケジュールリスト -->
    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource NxSurface}" CornerRadius="10" ClipToBounds="True" Margin="0,0,12,0">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{StaticResource NxSurface2}">
          <Grid>
            <TextBlock Text="スケジュール一覧" FontSize="13" FontWeight="Medium" Foreground="#90CAF9" VerticalAlignment="Center"/>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
              <Button Content="➕ 追加" Command="{Binding AddEntryCommand}"
                      Style="{StaticResource MaterialDesignFlatButton}" FontSize="12"/>
              <Button Content="🗑 削除" Command="{Binding RemoveEntryCommand}"
                      Style="{StaticResource MaterialDesignFlatButton}" FontSize="12" Foreground="#FF5252"/>
              <Button Content="💾 保存" Command="{Binding SaveScheduleCommand}"
                      Style="{StaticResource MaterialDesignFlatButton}" FontSize="12"/>
            </StackPanel>
          </Grid>
        </Border>
        <ListView ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}"
                  Background="Transparent" BorderThickness="0">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border Padding="12,10" CornerRadius="6" Margin="4,2">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                        <Setter Property="Background" Value="#1A2A4A"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" Foreground="White"/>
                    <TextBlock FontSize="11" Opacity="0.6" Foreground="White">
                      <Run Text="{Binding RepeatType}"/>
                      <Run Text=" — 次回: "/>
                      <Run Text="{Binding NextRunTime, StringFormat={}{0:MM/dd HH:mm}}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding MacroFilePath}" FontSize="10" Opacity="0.5" Foreground="#90CAF9"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2" FontSize="11" Opacity="0.6" VerticalAlignment="Center">
                    <Run Text="実行: "/>
                    <Run Text="{Binding RunCount}"/>
                    <Run Text=" 回"/>
                  </TextBlock>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </DockPanel>
    </Border>

    <!-- 詳細設定パネル -->
    <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource NxSurface}" CornerRadius="10" Padding="0" ClipToBounds="True">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{StaticResource NxSurface2}">
          <TextBlock Text="詳細設定" FontSize="13" FontWeight="Medium" Foreground="#90CAF9"/>
        </Border>
        <ScrollViewer>
          <StackPanel Margin="16" DataContext="{Binding SelectedEntry}">
            <TextBox Text="{Binding Name}" md:HintAssist.Hint="スケジュール名"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" Text="{Binding MacroFilePath}"
                       md:HintAssist.Hint="マクロファイルパス"
                       Style="{StaticResource MaterialDesignOutlinedTextBox}"
                       IsReadOnly="True" Margin="0,0,8,0"/>
              <Button Grid.Column="1" Content="参照" Command="{Binding DataContext.SelectMacroFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </Grid>

            <ComboBox md:HintAssist.Hint="繰り返しタイプ"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      SelectedItem="{Binding RepeatType}" Margin="0,0,0,12">
              <models:ScheduleRepeatType>Once</models:ScheduleRepeatType>
              <models:ScheduleRepeatType>Interval</models:ScheduleRepeatType>
              <models:ScheduleRepeatType>Daily</models:ScheduleRepeatType>
              <models:ScheduleRepeatType>Weekly</models:ScheduleRepeatType>
            </ComboBox>

            <md:DateTimePicker SelectedDate="{Binding ScheduledTime}"
                               md:HintAssist.Hint="実行日時"
                               Style="{StaticResource MaterialDesignOutlinedDateTimePicker}"
                               Margin="0,0,0,12"/>

            <md:NumericUpDown Value="{Binding IntervalMs}" Minimum="1000"
                              md:HintAssist.Hint="間隔(ms) — Interval モード用"
                              Style="{StaticResource MaterialDesignOutlinedNumericUpDown}"
                              Margin="0,0,0,12"/>

            <md:NumericUpDown Value="{Binding MaxRunCount}" Minimum="0"
                              md:HintAssist.Hint="最大実行回数 (0=無制限)"
                              Style="{StaticResource MaterialDesignOutlinedNumericUpDown}"
                              Margin="0,0,0,16"/>

            <Button Content="💾 変更を保存" Command="{Binding DataContext.SaveScheduleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource NxPrimary}" HorizontalAlignment="Stretch"/>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
