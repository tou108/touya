<UserControl x:Class="NXMacroAdvanced.Views.ImageRecognitionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource NxBg}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="300"/>
    </Grid.ColumnDefinitions>

    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="👁 画像認識 / OCR"
               FontSize="22" FontWeight="Light" Foreground="White" Margin="0,0,0,20"/>

    <!-- 左: テンプレートテスト -->
    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">

      <!-- キャプチャデバイス -->
      <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="📡 キャプチャデバイス" FontWeight="Medium" Foreground="#90CAF9" Margin="0,0,0,10"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <md:NumericUpDown Grid.Column="0" Value="{Binding CaptureDeviceIndex}" Minimum="0"
                              md:HintAssist.Hint="デバイス番号 (0=最初のキャプチャボード)"
                              Style="{StaticResource MaterialDesignOutlinedNumericUpDown}" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="🔌 接続" Command="{Binding OpenCaptureDeviceCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
          </Grid>
          <TextBlock Text="{Binding TestResult}" Margin="0,8,0,0" FontSize="12" Foreground="#90CAF9"/>
        </StackPanel>
      </Border>

      <!-- テンプレートマッチング -->
      <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="🖼 テンプレートマッチング" FontWeight="Medium" Foreground="#90CAF9" Margin="0,0,0,10"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding TemplatePath}"
                     md:HintAssist.Hint="テンプレート画像パス (.png / .jpg)"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     IsReadOnly="True" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="📁 参照" Command="{Binding SelectTemplateCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
          </Grid>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Value="{Binding Threshold}" Minimum="0.5" Maximum="1.0"
                    TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="1" VerticalAlignment="Center">
              <Run Text="閾値: "/>
              <Run Text="{Binding Threshold, StringFormat=P0}"/>
            </TextBlock>
          </Grid>
          <StackPanel Orientation="Horizontal">
            <Button Content="🔍 テストマッチ" Command="{Binding TestMatchCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource NxPrimary}" Margin="0,0,8,0"/>
            <Button Content="📷 スクリーンショット保存" Command="{Binding CaptureScreenshotCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
          </StackPanel>
          <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="6" Background="{StaticResource NxSurface2}"
                  Visibility="{Binding TestResult, Converter={conv:StringToVisibilityConverter}, Source={StaticResource conv}}">
            <TextBlock Text="{Binding TestResult}" FontSize="13" Foreground="#69F0AE"/>
          </Border>
        </StackPanel>
      </Border>

      <!-- OCR -->
      <Border Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16">
        <StackPanel>
          <TextBlock Text="📝 OCR 文字認識" FontWeight="Medium" Foreground="#90CAF9" Margin="0,0,0,10"/>
          <TextBox Text="{Binding OcrRegionText}"
                   md:HintAssist.Hint="認識領域 (x,y,幅,高さ) — 例: 100,200,400,80"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8"/>
          <Button Content="📝 OCR 実行" Command="{Binding RunOcrCommand}"
                  Style="{StaticResource MaterialDesignRaisedButton}"
                  Background="{StaticResource NxPrimary}" HorizontalAlignment="Left"/>
          <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="6" Background="{StaticResource NxSurface2}">
            <TextBlock Text="{Binding OcrResult}" FontFamily="Consolas" FontSize="13"
                       TextWrapping="Wrap" Foreground="#E0E0E0" MinHeight="40"/>
          </Border>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- 右: 使い方ガイド -->
    <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource NxSurface}" CornerRadius="10" Padding="16">
      <ScrollViewer>
        <StackPanel>
          <TextBlock Text="📖 使い方ガイド" FontWeight="Medium" Foreground="#90CAF9" Margin="0,0,0,12"/>
          <TextBlock FontSize="12" Foreground="#BDBDBD" TextWrapping="Wrap" LineHeight="20">
            <Run FontWeight="Bold" Foreground="White">テンプレート画像の作成:</Run>
            <LineBreak/>
            <Run>1. Switchの画面をスクリーンショットで撮影</Run>
            <LineBreak/>
            <Run>2. 認識したいUI部分をトリミングして保存</Run>
            <LineBreak/>
            <Run>3. 例: バトル開始ボタン、ダイアログのOKなど</Run>
            <LineBreak/><LineBreak/>
            <Run FontWeight="Bold" Foreground="White">マクロでの使い方:</Run>
            <LineBreak/>
            <Run Text="IF IMAGE_MATCH &quot;battle.png&quot; 0.9"/>
            <LineBreak/>
            <Run Text="  PRESS A 100"/>
            <LineBreak/>
            <Run Text="END_IF"/>
            <LineBreak/><LineBreak/>
            <Run FontWeight="Bold" Foreground="White">OCRの使い方:</Run>
            <LineBreak/>
            <Run>認識領域を指定して実行すると</Run>
            <LineBreak/>
            <Run>Switchの画面のテキストを読み取れます。</Run>
            <LineBreak/><LineBreak/>
            <Run FontWeight="Bold" Foreground="White">tessdata フォルダ:</Run>
            <LineBreak/>
            <Run>日本語OCRには jpn.traineddata が必要です。</Run>
            <LineBreak/>
            <Run>Tesseract の公式サイトからダウンロードして</Run>
            <LineBreak/>
            <Run>tessdata/ フォルダに配置してください。</Run>
          </TextBlock>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
