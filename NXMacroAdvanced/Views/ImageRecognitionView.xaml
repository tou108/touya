<UserControl x:Class="NXMacroAdvanced.Views.ImageRecognitionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource NxBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── ヘッダー ─── -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                       Text="画像認識 / OCR" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,16"/>

            <!-- ─── 左列: キャプチャデバイス + テンプレートマッチング ─── -->
            <StackPanel Grid.Row="1" Grid.Column="0">

                <!-- キャプチャデバイス -->
                <Border Background="{StaticResource NxSurface}" CornerRadius="8"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="📷 キャプチャデバイス" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource NxAccent}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding CaptureDeviceIndex, UpdateSourceTrigger=PropertyChanged}"
                                     md:HintAssist.Hint="デバイス番号 (0, 1, 2...)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <Button Grid.Column="2"
                                    Command="{Binding OpenCaptureDeviceCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource NxPrimary}"
                                    Content="接続" Height="36" Padding="12,0" FontSize="12"/>
                        </Grid>

                        <Border Background="{StaticResource NxSurface2}" CornerRadius="4"
                                Padding="10,6" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#555"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CaptureDeviceOpen}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource NxSuccess}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding TestResult}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding CaptureScreenshotCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="📸 スクリーンショット保存"
                                Height="34" FontSize="12" HorizontalAlignment="Left"/>

                        <TextBlock Text="{Binding ScreenshotPath}"
                                   FontSize="10" Margin="0,6,0,0"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- テンプレートマッチング -->
                <Border Background="{StaticResource NxSurface}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="🔍 テンプレートマッチング" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource NxAccent}" Margin="0,0,0,12"/>

                        <!-- テンプレート選択 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding TemplatePath, UpdateSourceTrigger=PropertyChanged}"
                                     md:HintAssist.Hint="テンプレート画像パス"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="2"
                                    Command="{Binding SelectTemplateCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="📂" Height="36" Width="42" FontSize="14"/>
                        </Grid>

                        <!-- 閾値スライダー -->
                        <TextBlock Style="{StaticResource SectionHeader}">
                            <Run Text="類似度閾値: "/>
                            <Run Text="{Binding Threshold, StringFormat={}{0:P0}}"/>
                        </TextBlock>
                        <Slider Value="{Binding Threshold}" Minimum="0.1" Maximum="1.0"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Style="{StaticResource MaterialDesignSlider}"
                                Margin="0,0,0,12"/>

                        <!-- テスト実行 -->
                        <Button Command="{Binding TestMatchCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource NxPrimary}"
                                Content="▶ マッチングテスト" Height="36"
                                HorizontalAlignment="Left" Margin="0,0,0,10" FontSize="13"/>

                        <!-- 結果 -->
                        <Border Background="{StaticResource NxSurface2}" CornerRadius="4" Padding="10,8">
                            <TextBlock Text="{Binding TestResult}"
                                       FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ─── 右列: OCR ─── -->
            <StackPanel Grid.Row="1" Grid.Column="2">
                <Border Background="{StaticResource NxSurface}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="📝 OCR テキスト認識" FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource NxAccent}" Margin="0,0,0,12"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="認識領域 (x,y,幅,高さ)"/>
                        <TextBox Text="{Binding OcrRegionText, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="例: 0,0,640,100"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontFamily="Consolas" Margin="0,0,0,12"/>

                        <Button Command="{Binding RunOcrCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource NxPrimary}"
                                Content="▶ OCR 実行" Height="36"
                                HorizontalAlignment="Left" Margin="0,0,0,12" FontSize="13"/>

                        <TextBlock Text="認識結果:" Style="{StaticResource SectionHeader}"/>
                        <Border Background="{StaticResource NxSurface2}" CornerRadius="6"
                                Padding="12" MinHeight="80">
                            <TextBox Text="{Binding OcrResult, Mode=OneWay}"
                                     FontFamily="Consolas, Yu Gothic UI, monospace"
                                     FontSize="13"
                                     Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxHeight="200"/>
                        </Border>

                        <Border Background="{StaticResource NxSurface2}" CornerRadius="6"
                                Padding="14,12" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="💡 使い方のヒント" FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,8"/>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Opacity="0.7" TextWrapping="Wrap" LineHeight="18">
                                    <Run Text="• キャプチャデバイス接続後にOCRを実行します"/>
                                    <LineBreak/>
                                    <Run Text="• 領域は画面の左上を (0,0) とした座標で指定します"/>
                                    <LineBreak/>
                                    <Run Text="• Tesseract OCR エンジンを使用しています"/>
                                    <LineBreak/>
                                    <Run Text="• マクロスクリプトから IF OCR_CONTAINS で条件分岐できます"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
