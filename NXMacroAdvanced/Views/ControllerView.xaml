<UserControl x:Class="NXMacroAdvanced.Views.ControllerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource NxBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="バーチャルコントローラー" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,16"/>

            <!-- ─── トリガー / ショルダー ─── -->
            <Border Background="{StaticResource NxSurface}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ZL"
                            Command="{Binding ToggleButtonCommand}" CommandParameter="ZL"
                            Style="{StaticResource TriggerButton}" Background="{StaticResource NxPrimary}"/>
                    <Button Grid.Column="1" Content="L"
                            Command="{Binding ToggleButtonCommand}" CommandParameter="L"
                            Style="{StaticResource TriggerButton}" Background="{StaticResource NxSurface2}"/>
                    <Button Grid.Column="2" Content="R"
                            Command="{Binding ToggleButtonCommand}" CommandParameter="R"
                            Style="{StaticResource TriggerButton}" Background="{StaticResource NxSurface2}"/>
                    <Button Grid.Column="3" Content="ZR"
                            Command="{Binding ToggleButtonCommand}" CommandParameter="ZR"
                            Style="{StaticResource TriggerButton}" Background="{StaticResource NxPrimary}"/>
                </Grid>
            </Border>

            <!-- ─── メインコントローラー ─── -->
            <Border Background="{StaticResource NxSurface}" CornerRadius="12" Padding="20" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左側: 十字キー + 左スティック -->
                    <StackPanel Grid.Column="0">
                        <!-- 左スティック -->
                        <TextBlock Text="左スティック" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
                        <Grid Width="120" Height="120" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Ellipse Fill="{StaticResource NxSurface2}" Width="120" Height="120"/>
                            <Slider Value="{Binding LStickY}" Minimum="0" Maximum="1"
                                    Orientation="Vertical" HorizontalAlignment="Center"
                                    Height="100" TickFrequency="0.1" IsSnapToTickEnabled="False"/>
                            <Slider Value="{Binding LStickX}" Minimum="0" Maximum="1"
                                    VerticalAlignment="Center" Width="100"
                                    TickFrequency="0.1" IsSnapToTickEnabled="False"/>
                        </Grid>
                        <Button Content="中央" Command="{Binding CenterLStickCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Center" FontSize="11"/>

                        <!-- 十字キー -->
                        <TextBlock Text="十字キー" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
                        <Grid Width="120" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Row="0" Grid.Column="1" Content="↑" Style="{StaticResource DPadButton}"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Up"/>
                            <Button Grid.Row="1" Grid.Column="0" Content="←" Style="{StaticResource DPadButton}"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Left"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="→" Style="{StaticResource DPadButton}"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Right"/>
                            <Button Grid.Row="2" Grid.Column="1" Content="↓" Style="{StaticResource DPadButton}"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Down"/>
                        </Grid>
                    </StackPanel>

                    <!-- 中央: +/−/Home/Capture + スティックボタン -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="100">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Content="−" Width="42" Height="30"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="Minus"
                                    Style="{StaticResource MaterialDesignFlatButton}" FontSize="16"/>
                            <Button Content="+" Width="42" Height="30"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="Plus"
                                    Style="{StaticResource MaterialDesignFlatButton}" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Width="38" Height="38"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="Home"
                                    Style="{StaticResource MaterialDesignIconButton}" Margin="2">
                                <md:PackIcon Kind="Home" Width="18" Height="18"/>
                            </Button>
                            <Button Width="38" Height="38"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="Capture"
                                    Style="{StaticResource MaterialDesignIconButton}" Margin="2">
                                <md:PackIcon Kind="Camera" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="L3" Width="42" Height="30"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="LStick"
                                    Style="{StaticResource MaterialDesignFlatButton}" FontSize="11"/>
                            <Button Content="R3" Width="42" Height="30"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="RStick"
                                    Style="{StaticResource MaterialDesignFlatButton}" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右側: フェイスボタン + 右スティック -->
                    <StackPanel Grid.Column="2">
                        <!-- フェイスボタン -->
                        <TextBlock Text="ボタン" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
                        <Grid Width="160" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Row="0" Grid.Column="1" Content="X"
                                    Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnX}"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="X"/>
                            <Button Grid.Row="1" Grid.Column="0" Content="Y"
                                    Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnY}"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="Y"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="A"
                                    Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnA}"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="A"/>
                            <Button Grid.Row="2" Grid.Column="1" Content="B"
                                    Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnB}" Foreground="#222"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="B"/>
                        </Grid>

                        <!-- 右スティック -->
                        <TextBlock Text="右スティック" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
                        <Grid Width="120" Height="120" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Ellipse Fill="{StaticResource NxSurface2}" Width="120" Height="120"/>
                            <Slider Value="{Binding RStickY}" Minimum="0" Maximum="1"
                                    Orientation="Vertical" HorizontalAlignment="Center"
                                    Height="100" TickFrequency="0.1" IsSnapToTickEnabled="False"/>
                            <Slider Value="{Binding RStickX}" Minimum="0" Maximum="1"
                                    VerticalAlignment="Center" Width="100"
                                    TickFrequency="0.1" IsSnapToTickEnabled="False"/>
                        </Grid>
                        <Button Content="中央" Command="{Binding CenterRStickCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── クイックマクロ / リセット ─── -->
            <Border Background="{StaticResource NxSurface}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="クイックマクロ" Style="{StaticResource SectionHeader}"/>
                    <WrapPanel>
                        <Button Content="A×10連打"
                                Command="{Binding QuickMacroCommand}" CommandParameter="A10"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" FontSize="12"/>
                        <Button Content="B→A"
                                Command="{Binding QuickMacroCommand}" CommandParameter="BA"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" FontSize="12"/>
                        <Button Content="スティック上"
                                Command="{Binding QuickMacroCommand}" CommandParameter="StickUp"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" FontSize="12"/>
                        <Button Content="⬜ 全リセット"
                                Command="{Binding NeutralAllCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#FF5252" FontSize="12" Margin="0,0,0,8"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
