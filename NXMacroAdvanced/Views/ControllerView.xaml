<UserControl x:Class="NXMacroAdvanced.Views.ControllerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource NxBg}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <md:PackIcon Kind="GamepadVariant" Width="24" Height="24" Foreground="#90CAF9" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="バーチャルコントローラー" FontSize="20" FontWeight="Light" Foreground="White"/>
            <TextBlock Text=" — クリックして入力" FontSize="14" Foreground="#808080" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
        </StackPanel>

        <!-- コントローラー本体 -->
        <Border Grid.Row="1" Background="{StaticResource NxSurface}" CornerRadius="40"
                Padding="30,24" Margin="0,0,0,16" MaxWidth="760" MaxHeight="400"
                HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>   <!-- 左側 -->
                    <ColumnDefinition Width="180"/> <!-- 中央 -->
                    <ColumnDefinition Width="*"/>   <!-- 右側 -->
                </Grid.ColumnDefinitions>

                <!-- ══════════════ 左サイド ══════════════ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- ZL / L トリガー -->
                        <RowDefinition Height="*"/>    <!-- スティック + Dpad -->
                    </Grid.RowDefinitions>

                    <!-- ZL / L トリガー -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <Button Content="ZL" Style="{StaticResource TriggerButton}"
                                Background="{Binding BtnZL, Converter={conv:BoolToColorConverter}, ConverterParameter=#37474F|#546E7A}"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="ZL"/>
                        <Button Content="L" Style="{StaticResource TriggerButton}"
                                Background="{Binding BtnL, Converter={conv:BoolToColorConverter}, ConverterParameter=#37474F|#546E7A}"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="L"/>
                    </StackPanel>

                    <!-- 左スティック -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Dパッド -->
                        <Grid Grid.Row="0" Width="110" Height="110"
                              VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Style="{StaticResource DPadButton}" Content="▲"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Up"/>
                            <Button Style="{StaticResource DPadButton}" Content="▼"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Down"/>
                            <Button Style="{StaticResource DPadButton}" Content="◀"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Left"/>
                            <Button Style="{StaticResource DPadButton}" Content="▶"
                                    VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Command="{Binding ToggleDPadCommand}" CommandParameter="Right"/>
                            <!-- 中央 -->
                            <Border Width="30" Height="30" Background="{StaticResource NxSurface2}"
                                    CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 左スティック (アナログ) -->
                        <Border Grid.Row="1" Background="{StaticResource NxSurface2}"
                                CornerRadius="8" Padding="8" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="L スティック" FontSize="10" Opacity="0.6" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="X:" FontSize="10" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Grid.Row="0" Minimum="0" Maximum="1" Value="{Binding LStickX}" TickFrequency="0.5"/>
                                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Y:" FontSize="10" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Grid.Row="1" Minimum="0" Maximum="1" Value="{Binding LStickY}" TickFrequency="0.5"/>
                                </Grid>
                                <Button Content="中央に戻す" FontSize="10"
                                        Command="{Binding CenterLStickCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="22" Padding="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ══════════════ 中央 ══════════════ -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Minus / Plus / Home / Capture -->
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Content="−" Style="{StaticResource MaterialDesignFlatButton}"
                                Width="36" Height="36" FontSize="16"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="Minus"/>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Width="36" Height="36"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="Home">
                            <md:PackIcon Kind="Home" Width="18" Height="18"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Width="36" Height="36"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="Capture">
                            <md:PackIcon Kind="Camera" Width="18" Height="18"/>
                        </Button>
                        <Button Content="＋" Style="{StaticResource MaterialDesignFlatButton}"
                                Width="36" Height="36" FontSize="16"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="Plus"/>
                    </WrapPanel>

                    <!-- 全解放ボタン -->
                    <Button Content="ALL RELEASE" Command="{Binding NeutralAllCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="11" Height="32" Foreground="#FF5252" BorderBrush="#FF5252"/>
                </StackPanel>

                <!-- ══════════════ 右サイド ══════════════ -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- ZR / R トリガー -->
                        <RowDefinition Height="*"/>    <!-- ABXYボタン + 右スティック -->
                    </Grid.RowDefinitions>

                    <!-- ZR / R トリガー -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                        <Button Content="R" Style="{StaticResource TriggerButton}"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="R"/>
                        <Button Content="ZR" Style="{StaticResource TriggerButton}"
                                Command="{Binding ToggleButtonCommand}" CommandParameter="ZR"/>
                    </StackPanel>

                    <!-- ABXY ボタン -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Width="140" Height="140"
                              HorizontalAlignment="Right" VerticalAlignment="Top">
                            <!-- Y (上) -->
                            <Button Content="Y" Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnY}"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    IsChecked="{Binding BtnY}"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="Y"/>
                            <!-- A (右) -->
                            <Button Content="A" Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnA}"
                                    VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="A"/>
                            <!-- B (下) -->
                            <Button Content="B" Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnB}"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="B"/>
                            <!-- X (左) -->
                            <Button Content="X" Style="{StaticResource GamepadButton}"
                                    Background="{StaticResource BtnX}"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Command="{Binding ToggleButtonCommand}" CommandParameter="X"/>
                        </Grid>

                        <!-- 右スティック -->
                        <Border Grid.Row="1" Background="{StaticResource NxSurface2}"
                                CornerRadius="8" Padding="8" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="R スティック" FontSize="10" Opacity="0.6" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="X:" FontSize="10" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Grid.Row="0" Minimum="0" Maximum="1" Value="{Binding RStickX}" TickFrequency="0.5"/>
                                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Y:" FontSize="10" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Grid.Row="1" Minimum="0" Maximum="1" Value="{Binding RStickY}" TickFrequency="0.5"/>
                                </Grid>
                                <Button Content="中央に戻す" FontSize="10"
                                        Command="{Binding CenterRStickCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="22" Padding="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- クイックマクロボタン -->
        <Border Grid.Row="2" Background="{StaticResource NxSurface}" CornerRadius="10" Padding="14,10">
            <StackPanel>
                <TextBlock Text="クイック入力" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <Button Content="A×10" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" FontSize="12" Height="32"
                            Command="{Binding QuickMacroCommand}" CommandParameter="A10"/>
                    <Button Content="B+A" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" FontSize="12" Height="32"
                            Command="{Binding QuickMacroCommand}" CommandParameter="BA"/>
                    <Button Content="↑スティック" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" FontSize="12" Height="32"
                            Command="{Binding QuickMacroCommand}" CommandParameter="StickUp"/>
                    <Button Content="HOME" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" FontSize="12" Height="32"
                            Command="{Binding ToggleButtonCommand}" CommandParameter="Home"/>
                    <Button Content="CAP" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="4" FontSize="12" Height="32"
                            Command="{Binding ToggleButtonCommand}" CommandParameter="Capture"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
