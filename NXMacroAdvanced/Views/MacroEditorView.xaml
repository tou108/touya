<UserControl x:Class="NXMacroAdvanced.Views.MacroEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:NXMacroAdvanced.Converters"
             Background="{StaticResource NxBg}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter      x:Key="InvBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- ツールバー -->
            <RowDefinition Height="*"/>   <!-- エディター + ログ -->
            <RowDefinition Height="Auto"/> <!-- エラー表示 -->
            <RowDefinition Height="Auto"/> <!-- 実行設定 -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════ -->
        <!-- ツールバー -->
        <!-- ════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource NxSurface}" Padding="8,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="📝 マクロエディター"
                           FontSize="16" FontWeight="Light" Foreground="White"
                           VerticalAlignment="Center" Margin="8,0,20,0"/>

                <!-- ファイル操作 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="新規" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding NewFileCommand}" FontSize="12"/>
                    <Button Content="開く" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding OpenFileCommand}" FontSize="12"/>
                    <Button Content="保存" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding SaveFileCommand}" FontSize="12"/>
                    <Button Content="名前を付けて保存" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding SaveFileAsCommand}" FontSize="12"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
                    <Button Content="✅ 構文確認" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding ValidateCommand}" FontSize="12" Foreground="#69F0AE"/>
                </StackPanel>

                <!-- ファイル名 -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding CurrentFile, StringFormat='  📄 {0}'}"
                           VerticalAlignment="Center" FontSize="11" Opacity="0.6"/>
                <TextBlock DockPanel.Dock="Left"
                           Text=" *" Foreground="#FFD740" VerticalAlignment="Center"
                           Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>

                <!-- 実行コントロール (右端) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding StopCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#B71C1C" Height="34" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Stop" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="停止"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PauseCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#E65100" Height="34" Margin="4,0">
                        <md:PackIcon Kind="{Binding IsPaused, Converter={conv:BoolToIconConverter}, ConverterParameter=Play|Pause}"
                                     Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding RunCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource NxSuccess}" Height="34" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Play" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="実行"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════ -->
        <!-- エディターエリア (左) + ログ (右) -->
        <!-- ════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- テキストエディター -->
            <Border Grid.Column="0" Background="{StaticResource NxSurface}">
                <TextBox Text="{Binding ScriptText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="True"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="13"
                         Foreground="#E0E0E0"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="12"
                         IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"
                         md:TextFieldAssist.HasClearButton="False"/>
            </Border>

            <!-- リサイズグリッパー -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#1A3A6C" Cursor="SizeWE"/>

            <!-- 実行ログ -->
            <Border Grid.Column="2" Background="{StaticResource NxSurface}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="8,6" Background="{StaticResource NxSurface2}">
                        <TextBlock Text="📋 実行ログ" FontSize="12" FontWeight="Medium" Foreground="#90CAF9"/>
                    </Border>

                    <!-- 進捗バー -->
                    <ProgressBar DockPanel.Dock="Top" Value="{Binding Progress}" Height="4"
                                 Foreground="{StaticResource NxSuccess}" Margin="0"/>

                    <ListBox ItemsSource="{Binding RunLog}"
                             Background="Transparent" BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#B0BEC5"
                                           TextWrapping="Wrap" Margin="4,1"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════ -->
        <!-- エラーメッセージ -->
        <!-- ════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#B71C1C" Padding="10,6"
                Visibility="{Binding ErrorMessages, Converter={conv:StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessages}" Foreground="White"
                       FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" MaxHeight="80"/>
        </Border>

        <!-- ════════════════════════════════════════ -->
        <!-- 実行設定フッター -->
        <!-- ════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource NxSurface}" Padding="12,8">
            <WrapPanel>
                <TextBlock Text="ループ回数:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                <CheckBox Content="無限ループ" IsChecked="{Binding InfiniteLoop}"
                          Margin="0,0,12,0" VerticalAlignment="Center"/>
                <md:NumericUpDown Value="{Binding LoopCount}" Minimum="1" Maximum="9999"
                                  Width="80" Margin="0,0,20,0"
                                  IsEnabled="{Binding InfiniteLoop, Converter={StaticResource InvBool}}"/>

                <TextBlock Text="スクリプト構文 (クリックで参照):" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.7"/>
                <Button Content="PRESS A 100 | WAIT 500 | LOOP N | IF IMAGE_MATCH | STICK L 128 0 500"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        FontSize="10" FontFamily="Consolas"
                        Foreground="#90CAF9" Padding="4,0"
                        ToolTip="クリックしてマクロ構文ヘルプを開く"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
